rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // PRODUCTS — 누구나 읽기, 관리자만 쓰기
    // ═══════════════════════════════════════════
    match /products/{productId} {
      allow read: if true;

      // 관리자(Firebase Auth 로그인)만 생성/수정 가능
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAny(['nameKo', 'nameEn', 'price'])
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;

      allow delete: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // ORDERS — 누구나 읽기 (고객 조회), 생성은 필드 검증, 수정/삭제는 조건부
    // ═══════════════════════════════════════════
    match /orders/{orderId} {
      // 누구나 주문 조회 가능 (전화번호로 필터)
      allow read: if true;

      // 주문 생성: 필수 필드 검증 (고객이 주문)
      allow create: if
        request.resource.data.keys().hasAll(['orderNum', 'status', 'items', 'customer', 'phone', 'total'])
        && request.resource.data.status == 'pending_payment'
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 10;

      // 주문 수정: 관리자(인증됨) 또는 제한적 고객 수정 (결제 정보 + 상태만)
      allow update: if request.auth != null
        || (
          // 고객은 pending_payment → payment_submitted 전환만 가능
          resource.data.status == 'pending_payment'
          && request.resource.data.status == 'payment_submitted'
          // 고객이 바꿀 수 없는 필드 보호: items, total, phone, customer는 변경 불가
          && request.resource.data.total == resource.data.total
          && request.resource.data.phone == resource.data.phone
          && request.resource.data.orderNum == resource.data.orderNum
        );

      // 주문 삭제: 관리자만 또는 미결제 주문만
      allow delete: if request.auth != null
        || resource.data.status == 'pending_payment';
      // NOTE: 향후 관리자 전용으로 변경 권장: allow delete: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // CATEGORIES — 누구나 읽기, 관리자만 쓰기
    // ═══════════════════════════════════════════
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // PROMOS — 누구나 읽기, 관리자만 쓰기
    // ═══════════════════════════════════════════
    match /promos/{promoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // 그 외 모든 컬렉션 — 접근 차단
    // ═══════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
