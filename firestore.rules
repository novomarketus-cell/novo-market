rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAny(['nameKo', 'nameEn', 'price'])
        && request.resource.data.price is number
        && request.resource.data.price >= 0;
      allow delete: if request.auth != null;
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['orderNum', 'status', 'items', 'customer', 'phone', 'total'])
        && request.resource.data.status == 'pending_payment'
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 10;
      allow update: if true;
      allow delete: if request.auth != null
        || resource.data.status == 'pending_payment';
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PROMOS
    match /promos/{promoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
